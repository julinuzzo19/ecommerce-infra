    {
      "name": "🔄 Flujos End-to-End",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('jwt_token', res.token);",
                  "  pm.collectionVariables.set('user_id', res.userId);",
                  "  console.log('✅ Paso 1/4 OK — Token guardado');",
                  "  pm.test('Login exitoso', () => pm.response.to.have.status(200));",
                  "} else {",
                  "  console.error('❌ Login fallido', JSON.stringify(res));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
