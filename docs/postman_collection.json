    {
      "name": "🔐 Auth via Gateway (:3000/auth)",
      "item": [
        {
          "name": "Login via Gateway",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// En Tests del request de Login",
                  "const cookies = pm.cookies.get('access_token');",
                  "",
                  "if (cookies) {",
                  "  pm.collectionVariables.set('access_token', cookies);",
                  "} else {",
                  "  // Fallback: si el auth service devuelve token en body directamente",
                  "  const res = pm.response.json();",
                  "  if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "  } else {",
                  "    console.log('❌ No se encontró token ni cookie');",
                  "  }",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/auth/login",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
